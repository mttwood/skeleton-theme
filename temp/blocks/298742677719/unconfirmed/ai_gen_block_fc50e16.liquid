{% doc %}
  @prompt
    bring in the models.info metaobkect, no that's not it, i want to show the models info we assined tot he product. You created  an entirely different thing, it's the model_info metaobject, why is it saying no model info assigned tot he product when there is
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-model-info-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-product-model-info-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-product-model-info-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-model-info-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-model-info-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-product-model-info-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-model-info-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-model-info-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-product-model-info-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-product-model-info-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-product-model-info-meta-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-model-info-meta-item-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
  }

  .ai-product-model-info-meta-label-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-product-model-info-meta-value-{{ ai_gen_id }} {
    font-weight: 400;
  }

  .ai-product-model-info-empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
  }

  @media screen and (min-width: 750px) {
    .ai-product-model-info-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.layout }};
      align-items: {{ block.settings.alignment }};
    }

    .ai-product-model-info-image-wrapper-{{ ai_gen_id }} {
      {% if block.settings.layout == 'row' %}
        flex: 0 0 {{ block.settings.image_width }}%;
      {% endif %}
    }

    .ai-product-model-info-content-{{ ai_gen_id }} {
      {% if block.settings.layout == 'row' %}
        flex: 1;
      {% endif %}
    }
  }
{% endstyle %}

<product-model-info-{{ ai_gen_id }}
  class="ai-product-model-info-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% assign model_info = product.metafields.custom.model_info.value %}
  
  {% if model_info != blank %}
    <div class="ai-product-model-info-container-{{ ai_gen_id }}">
      {% if block.settings.show_image %}
        <div class="ai-product-model-info-image-wrapper-{{ ai_gen_id }}">
          {% if model_info.image %}
            <img
              src="{{ model_info.image | image_url: width: 800 }}"
              alt="{{ model_info.image.alt | escape }}"
              class="ai-product-model-info-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ model_info.image.width }}"
              height="{{ model_info.image.height }}"
            >
          {% else %}
            <div class="ai-product-model-info-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-product-model-info-content-{{ ai_gen_id }}">
        {% if block.settings.show_title and model_info.name %}
          <h3 class="ai-product-model-info-title-{{ ai_gen_id }}">{{ model_info.name }}</h3>
        {% endif %}

        {% if block.settings.show_description and model_info.bio %}
          <div class="ai-product-model-info-description-{{ ai_gen_id }}">
            {{ model_info.bio }}
          </div>
        {% endif %}

        {% if block.settings.show_metadata %}
          <div class="ai-product-model-info-meta-{{ ai_gen_id }}">
            {% if model_info.height %}
              <div class="ai-product-model-info-meta-item-{{ ai_gen_id }}">
                <span class="ai-product-model-info-meta-label-{{ ai_gen_id }}">Height:</span>
                <span class="ai-product-model-info-meta-value-{{ ai_gen_id }}">{{ model_info.height }}</span>
              </div>
            {% endif %}
            
            {% if model_info.size %}
              <div class="ai-product-model-info-meta-item-{{ ai_gen_id }}">
                <span class="ai-product-model-info-meta-label-{{ ai_gen_id }}">Size:</span>
                <span class="ai-product-model-info-meta-value-{{ ai_gen_id }}">{{ model_info.size }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="ai-product-model-info-empty-{{ ai_gen_id }}">
      No model information assigned to this product
    </div>
  {% endif %}
</product-model-info-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductModelInfo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('product-model-info-{{ ai_gen_id }}', ProductModelInfo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product model info",
  "settings": [
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show bio",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_metadata",
      "label": "Show height and size",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "column",
          "label": "Stacked"
        },
        {
          "value": "row",
          "label": "Side by side"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between elements",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Content spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Metadata color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "meta_size",
      "label": "Metadata size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Product model info"
    }
  ]
}
{% endschema %}
