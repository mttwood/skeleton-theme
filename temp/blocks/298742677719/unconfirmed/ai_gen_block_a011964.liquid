{% doc %}
  @prompt
    Update the existing "Product model info" block in the custom section to fetch and display the model_info metaobject from the product metafield with namespace "models" and key "model_info". The metaobject has fields: bust, height, waist, and hips. Display these fields in a clean, readable format on the product page. The metafield type is mixed_reference pointing to a metaobject of type model_info.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% assign model_info_metaobject = product.metafields.models.model_info.value %}

{% style %}
  .ai-model-info-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-model-info__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-model-info__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.spacing }}px;
  }

  .ai-model-info__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-model-info__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 500;
    text-transform: {{ block.settings.label_transform }};
  }

  .ai-model-info__value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-model-info__empty-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-model-info__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-model-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if model_info_metaobject %}
    {% if block.settings.heading != blank %}
      <h3 class="ai-model-info__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}

    <div class="ai-model-info__grid-{{ ai_gen_id }}">
      {% if model_info_metaobject.bust %}
        <div class="ai-model-info__item-{{ ai_gen_id }}">
          <div class="ai-model-info__label-{{ ai_gen_id }}">{{ block.settings.bust_label }}</div>
          <div class="ai-model-info__value-{{ ai_gen_id }}">{{ model_info_metaobject.bust }}</div>
        </div>
      {% endif %}

      {% if model_info_metaobject.height %}
        <div class="ai-model-info__item-{{ ai_gen_id }}">
          <div class="ai-model-info__label-{{ ai_gen_id }}">{{ block.settings.height_label }}</div>
          <div class="ai-model-info__value-{{ ai_gen_id }}">{{ model_info_metaobject.height }}</div>
        </div>
      {% endif %}

      {% if model_info_metaobject.waist %}
        <div class="ai-model-info__item-{{ ai_gen_id }}">
          <div class="ai-model-info__label-{{ ai_gen_id }}">{{ block.settings.waist_label }}</div>
          <div class="ai-model-info__value-{{ ai_gen_id }}">{{ model_info_metaobject.waist }}</div>
        </div>
      {% endif %}

      {% if model_info_metaobject.hips %}
        <div class="ai-model-info__item-{{ ai_gen_id }}">
          <div class="ai-model-info__label-{{ ai_gen_id }}">{{ block.settings.hips_label }}</div>
          <div class="ai-model-info__value-{{ ai_gen_id }}">{{ model_info_metaobject.hips }}</div>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-model-info__empty-{{ ai_gen_id }}">
      No model information available for this product
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Product model info",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Model measurements"
    },
    {
      "type": "text",
      "id": "bust_label",
      "label": "Bust label",
      "default": "Bust"
    },
    {
      "type": "text",
      "id": "height_label",
      "label": "Height label",
      "default": "Height"
    },
    {
      "type": "text",
      "id": "waist_label",
      "label": "Waist label",
      "default": "Waist"
    },
    {
      "type": "text",
      "id": "hips_label",
      "label": "Hips label",
      "default": "Hips"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Value size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "label_transform",
      "label": "Label text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Product model info"
    }
  ]
}
{% endschema %}
